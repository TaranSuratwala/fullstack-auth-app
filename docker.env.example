# Local Docker environment template for teammates
# Copy this file to .env before running docker compose.

DB_NAME=auth_app
DB_USER=postgres
DB_PASSWORD=postgres

# Host port used to open the app in browser.
APP_PORT=8080
APP_PORT_SECOND=8081

# Replace with a strong random secret for shared usage.
JWT_SECRET=change_this_jwt_secret

# Optional: set to enable Google OAuth in local/shared container runs.
GOOGLE_CLIENT_ID=
